# CineMind AI — Environment Variables
# Copy this file to .env and fill in your values

# ── TMDB API ───────────────────────────────────────────────────────────────
# Get a FREE key at: https://www.themoviedb.org/settings/api
VITE_TMDB_API_KEY=2f7d49e6ef43d3ab0d750a130e131725

# ── Anthropic API (for live AI Chat) ──────────────────────────────────────
# Get your key at: https://console.anthropic.com
# Without this, the chatbot uses smart mock responses (still works great!)
VITE_ANTHROPIC_KEY=sk-ant-your_key_here
